# ---- Application ----
DEBUG=true
# Comma-separated origins, or * for all. For dev, the Vite server is on 5173.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- PostgreSQL ----
# Option A: full URL (takes precedence if set)
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ganesh_bhel_business_manager
# Option B: individual parts
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ganesh_bhel_business_manager

# ---- Gemini AI (optional; app works offline without it) ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# ---- Firebase auth (optional) ----
FIREBASE_ENABLED=false

# ---- Backups ----
MAX_BACKUPS=12
